# Copie este arquivo para .env.local e preencha com as chaves do seu
# projeto Firebase (Configurações do projeto > Geral > Seus apps > Web).
# A apiKey do Firebase é pública por design — a segurança real vem das
# regras do Firestore (firestore.rules), não do sigilo dessas variáveis.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcional: Firebase App Check com reCAPTCHA v3.
# Crie a chave no Console do Firebase/App Check e ative enforcement só
# depois de monitorar que navegadores legítimos estão recebendo tokens.
VITE_FIREBASE_APPCHECK_RECAPTCHA_SITE_KEY=

# Desenvolvimento local sem tocar no projeto Firebase real: rode
# `npm run emuladores` (Auth + Firestore, precisa de Java 21+) e preencha os
# valores acima com qualquer texto não vazio (ex: VITE_FIREBASE_API_KEY=demo,
# VITE_FIREBASE_PROJECT_ID=demo-tea-dev). Ver README § Desenvolvimento local.
VITE_USE_FIREBASE_EMULATOR=
