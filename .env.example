# Copie este arquivo para .env.local e preencha com as chaves do seu
# projeto Firebase (Configurações do projeto > Geral > Seus apps > Web).
# A apiKey do Firebase é pública por design — a segurança real vem das
# regras do Firestore (firestore.rules), não do sigilo dessas variáveis.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
